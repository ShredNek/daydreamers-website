{
	"linter": {
		"rules": {
			"nursery": {
				"noFloatingPromises": "error"
			},
			"complexity": {
				"useLiteralKeys": "off"
			},
			"a11y": {
				"useButtonType": "error",
				"useHtmlLang": "error",
				"useKeyWithClickEvents": "error",
				"useKeyWithMouseEvents": "error",
				"useValidAnchor": "error",
				"useValidAutocomplete": "error",
				"useValidLang": "error"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"useSortedAttributes": "on"
			}
		}
	},
	"files": {
		"includes": ["**", "!!**/node_modules", "!!.firebase", "!!**/dist"]
	}
}
